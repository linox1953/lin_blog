---
import FloatingButton from "@/components/common/FloatingButton.astro";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<FloatingButton
  id="back-to-top-btn"
  icon="material-symbols:keyboard-arrow-up-rounded"
  ariaLabel="Back to Top"
  onclick="backToTop()"
  class="hide"
/>

<script is:raw is:inline>
  // 返回顶部按钮点击行为
  function backToTop() {
    const wallpaperMode = document.documentElement.getAttribute(
      "data-wallpaper-mode",
    );
    const mainGrid = document.getElementById("main-grid");
    if (wallpaperMode === "fullscreen" && mainGrid) {
      mainGrid.scrollIntoView({ behavior: "smooth" });
    } else {
      window.scroll({ top: 0, behavior: "smooth" });
    }
  }

  // 按钮显隐管理器
  if (typeof window.BackToTopManager === "undefined") {
    window.BackToTopManager = class BackToTopManager {
      static _instance = null;

      constructor() {
        if (BackToTopManager._instance) {
          BackToTopManager._instance.destroy();
        }
        BackToTopManager._instance = this;
        this.button = document.getElementById("back-to-top-btn");
        this._scrollHandler = null;
        this._resizeHandler = null;
        this._threshold = 200;
        this.init();
      }

      init() {
        if (!this.button) return;
        this.updateThreshold();
        this.setupScrollListener();
        this._resizeHandler = this.updateThreshold.bind(this);
        window.addEventListener("resize", this._resizeHandler, {
          passive: true,
        });
      }

      updateThreshold() {
        const wallpaperMode = document.documentElement.getAttribute(
          "data-wallpaper-mode",
        );
        const mainGrid = document.getElementById("main-grid");
        if (wallpaperMode === "fullscreen" && mainGrid) {
          this._threshold =
            mainGrid.getBoundingClientRect().top + window.pageYOffset;
        } else {
          this._threshold = 200;
        }
      }

      setupScrollListener() {
        const updateVisibility = () => {
          if (!this.button) return;
          const scrollTop =
            window.pageYOffset || document.documentElement.scrollTop;
          if (scrollTop > this._threshold) {
            this.button.classList.remove("hide");
          } else {
            this.button.classList.add("hide");
          }
        };

        this._scrollHandler = updateVisibility;
        window.addEventListener("scroll", updateVisibility, { passive: true });
        updateVisibility();
      }

      destroy() {
        if (this._scrollHandler) {
          window.removeEventListener("scroll", this._scrollHandler);
          this._scrollHandler = null;
        }
        if (this._resizeHandler) {
          window.removeEventListener("resize", this._resizeHandler);
          this._resizeHandler = null;
        }
      }
    };
  }

  // 初始化入口
  function init() {
    new BackToTopManager();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
